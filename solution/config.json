{
  "provider": "openai",
  "model": "gpt-5.4-nano",
  "model_price_tier": "economy",
  "max_steps": 6,
  "loop_guard": true,
  "temperature": 0.0,
  "context_size": 6,
  "verbose_system": false,
  "timeout_ms": 60000,
  "max_completion_tokens": 220,
  "retry": {"enabled": true, "max_attempts": 2, "backoff_ms": 100},
  "cache": {"enabled": true},
  "normalize_unicode": true,
  "redact_pii": true,
  "session_drift_rate": 0.0,
  "context_reset_every": 6,
  "tool_error_rate": 0.0,
  "catalog_override": {"macbook": {"in_stock": true}},
  "route_rules": [],
  "planner": false,
  "verify": true,
  "self_consistency": 1,
  "tool_budget": 3,
  "prompt_file": "solution/prompt.txt",
  "examples_file": "solution/examples.json"
}
